# ---------- App Runtime ----------
QA_ROOT_MODEL_DIR=models/student_100k_T4_distilbert
QA_DIRECT_MODEL_DIR=models/lcppn_direct_classifier
QA_EVASIVE_MODEL_DIR=models/lcppn_evasive_classifier
QA_ALLOW_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
QA_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$
QA_LAZY_LOAD_MODELS=true
QA_MAX_BATCH_ITEMS=500
QA_LOW_CONF_THRESHOLD=0.45
QA_ENTITY_MIN_LENGTH=5

# ---------- LLM Labeling ----------
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_NAME=

# ---------- Stage C Data Flywheel ----------
QA_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/qa_review
QA_DATABASE_FALLBACK_TO_SQLITE=true
QA_DATABASE_FALLBACK_VERBOSE=false
QA_CELERY_BROKER_URL=redis://localhost:6379/0
QA_CELERY_RESULT_BACKEND=redis://localhost:6379/1
QA_CELERY_TASK_ALWAYS_EAGER=false
QA_DIFY_API_URL=https://api.dify.ai/v1/workflows/run
QA_DIFY_API_KEY=
QA_DIFY_USER=qa_reviewer
QA_DIFY_OUTPUT_PATH=data.outputs.result
QA_DIFY_MODEL_RESULT_AS_JSON=true
QA_DIFY_CONNECT_TIMEOUT=5
QA_DIFY_WRITE_TIMEOUT=10
QA_DIFY_READ_TIMEOUT=20
QA_REVIEW_ROOT_THRESHOLD=0.65
QA_REVIEW_SUB_THRESHOLD=0.65
QA_LONGTAIL_LABELS=战略性模糊,外部归因,合规与风险披露
QA_TRAINING_CORPUS_FILE=data/processed/review_training_corpus.csv
